hook 4:runtime_hook.sh {
#!/bin/sh
# session hook script; write commands here to execute on the host at the
# specified state
eth0_int=$(ip a | grep eth0@v)
if [ "X$eth0_int" == "X" ]; then
	ip link add eth0 type veth
fi
ip address add 10.1.1.15/26 dev eth0
ip link set eth0 up
ip link set veth0 up
bridge=$(brctl show | grep b.11. | awk '{ print $1 }')
brctl addif $bridge veth0
ip route add 10.1.1.64/26 via 10.1.1.1
ip route add 10.1.1.128/26 via 10.1.1.1
ip route add 10.0.3.0/24 via 10.1.1.1
ip route add 192.168.1.0/24 via 10.1.1.1
ip route add 172.16.1.0/26 via 10.1.1.1
sed -i '/^tun\*/i eth*' /etc/resolvconf/interface-order
resolvconf --enable-updates
echo "nameserver 10.1.1.70" | resolvconf -a eth0
resolvconf -u


}

hook 6:shutdown_hook.sh {
#!/bin/sh
# session shutdown hook script; write commands here to execute on the host at the
# specified state
bridge=$(brctl show | grep b.11. | awk '{ print $1 }')
brctl delif $bridge veth0
ip route del 10.1.1.64/26 via 10.1.1.1
ip route del 10.1.1.128/26 via 10.1.1.1
ip route del 10.0.3.0/24 via 10.1.1.1
ip route del 192.168.1.0/24 via 10.1.1.1
ip route del 172.16.1.0/26 via 10.1.1.1
resolvconf -d eth0
resolvconf -u
sed -i '/^eth\*/d' /etc/resolvconf/interface-order
ip address del 10.1.1.15/26 dev eth0
ip link veth0 down
ip link eth0 down


}

option global {
    interface_names yes
    ip_addresses yes
    ipv6_addresses yes
    node_labels yes
    link_labels yes
    show_api no
    background_images no
    annotations yes
    grid yes
    traffic_start 0
}

option session {
}

